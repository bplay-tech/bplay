# Neon DB — pooled (recommended for most uses)
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require

# Neon DB — unpooled (bypass pgbouncer)
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST.us-east-1.aws.neon.tech/neondb?sslmode=require

# Neon connection parameters
PGHOST=HOST-pooler.us-east-1.aws.neon.tech
PGHOST_UNPOOLED=HOST.us-east-1.aws.neon.tech
PGUSER=neondb_owner
PGDATABASE=neondb
PGPASSWORD=your-password-here

# Vercel Postgres compatible aliases
POSTGRES_URL=postgresql://USER:PASSWORD@HOST-pooler.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://USER:PASSWORD@HOST.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require
POSTGRES_USER=neondb_owner
POSTGRES_HOST=HOST-pooler.us-east-1.aws.neon.tech
POSTGRES_PASSWORD=your-password-here
POSTGRES_DATABASE=neondb
POSTGRES_URL_NO_SSL=postgresql://USER:PASSWORD@HOST-pooler.us-east-1.aws.neon.tech/neondb
POSTGRES_PRISMA_URL=postgresql://USER:PASSWORD@HOST-pooler.us-east-1.aws.neon.tech/neondb?channel_binding=require&connect_timeout=15&sslmode=require

# App
NEXT_PUBLIC_CHAIN_ID=1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth (NextAuth v5 uses AUTH_* prefix; keep NEXTAUTH_* as fallback)
AUTH_SECRET=your-secret-here-at-least-32-chars
AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# Seed
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=your-strong-password-here

# Email
RESEND_API_KEY=re_your_key_here

# Blockchain
ALCHEMY_WEBHOOK_SECRET=your_alchemy_webhook_secret
NEXT_PUBLIC_TREASURY_USDC_ADDRESS=0x_your_treasury_address
NEXT_PUBLIC_USDC_CONTRACT_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
